        {
          "type": "button",
          "text": { "type": "plain_text", "text": ":page_facing_up: Download PDF", "emoji": true },
          "value": "pdf_INV-9012",
          "action_id": "download_pdf"
        },
        {
          "type": "button",
          "text": { "type": "plain_text", "text": ":email: Send reminder", "emoji": true },
          "value": "remind_INV-9012",
          "action_id": "send_reminder"
        },
        {
          "type": "button",
          "text": { "type": "plain_text", "text": ":credit_card: Collect", "emoji": true },
          "value": "pay_INV-9012",
          "action_id": "collect_payment"
        }
      ]
    }
  ]

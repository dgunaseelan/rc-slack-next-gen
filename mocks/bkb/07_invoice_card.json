    {
      "type": "section",
      "text": { "type": "mrkdwn", "text": "*$45,915.28* USD  ·  :large_blue_circle: *Posted*  ·  Due *May 16, 2026* (_30 days_)" },
      "accessory": {
        "type": "image",
        "image_url": "https://placehold.co/80x80/ef4444/ffffff/png?text=Acme",
        "alt_text": "Acme Corp logo"
      }
    },
    {
      "type": "context",
      "elements": [
        { "type": "mrkdwn", "text": "Generated from <fakeurl.com|Order SO-2271> (from Q-8847)  ·  Terms Net-30  ·  Tax $3,499.28" }
